rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function hasRequiredUserFields() {
      let data = request.resource.data;
      return data.keys().hasAll(['uid', 'createdAt']) &&
             data.uid is string &&
             (!('email' in data) || (data.email is string && data.email.matches("^[a-zA-Z0-9._%+-]+@lzu\\.edu\\.cn$")));
    }
    function isUserUpdateValid() {
      let data = request.resource.data;
      let oldData = resource.data;
      let affectedKeys = data.diff(oldData).affectedKeys();
      return !affectedKeys.hasAny(['uid', 'createdAt']) &&
             (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() < 50)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 500)) &&
             (!('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() <= 1000)) &&
             (!('displayProfile' in data) || (data.displayProfile is string && data.displayProfile.size() <= 2000)) &&
             (!('aiSummary' in data) || (data.aiSummary is string && data.aiSummary.size() <= 2000)) &&
             (!('isParticipating' in data) || data.isParticipating is bool);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && hasRequiredUserFields() && request.resource.data.uid == userId;
      allow update: if isOwner(userId) && isUserUpdateValid();
    }

    match /likes/{likeId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
      allow create, update: if isAuthenticated() && 
                    request.resource.data.fromUserId == request.auth.uid &&
                    request.resource.data.toUserId is string &&
                    request.resource.data.keys().hasAll(['fromUserId', 'toUserId', 'createdAt']);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.fromUserId;
    }

    match /passes/{passId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromUserId);
      allow create, update: if isAuthenticated() && 
                    request.resource.data.fromUserId == request.auth.uid &&
                    request.resource.data.toUserId is string &&
                    request.resource.data.keys().hasAll(['fromUserId', 'toUserId', 'createdAt']);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.fromUserId;
    }

    match /matches/{matchId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.users);
      allow create, update: if isAuthenticated() && 
                    request.resource.data.users is list &&
                    request.resource.data.users.size() == 2;
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.users;
    }

    match /drops/{dropId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    request.resource.data.fromUserId == request.auth.uid &&
                    request.resource.data.keys().hasAll(['fromUserId', 'fromEmail', 'toEmail']);
      allow update: if isAuthenticated() && resource.data.fromUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.fromUserId == request.auth.uid;
    }
    
    match /archived_matches/{archiveId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    
    match /cupid_matches/{cupidId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.cupidUserId == request.auth.uid;
    }
    
    match /shared_chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
      allow create: if isAuthenticated() && request.resource.data.fromUserId == request.auth.uid;
    }

    match /buddy_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    request.resource.data.uid == request.auth.uid &&
                    request.resource.data.category is string &&
                    request.resource.data.title is string &&
                    request.resource.data.title.size() >= 4 &&
                    request.resource.data.title.size() <= 60 &&
                    request.resource.data.content is string &&
                    request.resource.data.content.size() >= 10 &&
                    request.resource.data.content.size() <= 600 &&
                    request.resource.data.keys().hasOnly(['uid', 'category', 'title', 'content', 'createdAt', 'expiresAt']);
      allow update: if isAuthenticated() &&
                    resource.data.uid == request.auth.uid &&
                    request.resource.data.uid == resource.data.uid &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    request.resource.data.category is string &&
                    request.resource.data.title is string &&
                    request.resource.data.title.size() >= 4 &&
                    request.resource.data.title.size() <= 60 &&
                    request.resource.data.content is string &&
                    request.resource.data.content.size() >= 10 &&
                    request.resource.data.content.size() <= 600 &&
                    request.resource.data.keys().hasOnly(['uid', 'category', 'title', 'content', 'createdAt', 'expiresAt']);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /buddy_comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    request.resource.data.uid == request.auth.uid &&
                    request.resource.data.postId is string &&
                    request.resource.data.content is string &&
                    request.resource.data.content.size() > 0 &&
                    request.resource.data.content.size() <= 300 &&
                    request.resource.data.keys().hasOnly(['postId', 'uid', 'content', 'createdAt']);
      allow update: if isAuthenticated() &&
                    resource.data.uid == request.auth.uid &&
                    request.resource.data.uid == resource.data.uid &&
                    request.resource.data.postId == resource.data.postId &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    request.resource.data.content is string &&
                    request.resource.data.content.size() > 0 &&
                    request.resource.data.content.size() <= 300 &&
                    request.resource.data.keys().hasOnly(['postId', 'uid', 'content', 'createdAt']);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
