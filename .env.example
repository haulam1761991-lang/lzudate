# VITE_GLM_FUNCTION_NAME: Cloud function name used by frontend.
VITE_GLM_FUNCTION_NAME="glmProxy"

# VITE_GLM_CHAT_MODEL: Optional chat model override for frontend requests.
VITE_GLM_CHAT_MODEL="glm-4.6v-flashx"

# Optional fallback model used when chat timeout occurs.
# Keep this unset if you want to strictly use flashX for normal chat.
# VITE_GLM_CHAT_FALLBACK_MODEL="glm-4.7"

# High-quality model used in selected scenarios (e.g. profile analysis, match reasoning).
VITE_GLM_HIGH_QUALITY_MODEL="glm-4.7"

# VITE_CLOUDBASE_ENV_ID: Tencent CloudBase Environment ID
VITE_CLOUDBASE_ENV_ID="your-env-id"

# VITE_CLOUDBASE_REGION: Tencent CloudBase Region (e.g., ap-shanghai, ap-guangzhou)
VITE_CLOUDBASE_REGION="ap-shanghai"

# VITE_CLOUDBASE_TIMEOUT_MS: Frontend SDK request timeout (ms), default 65000.
VITE_CLOUDBASE_TIMEOUT_MS="65000"

# Cloud function runtime variable (set in Tencent Cloud console, not in Vite env file):
# GLM_API_KEY="your-zhipu-glm-api-key"
# GLM_CHAT_MODEL="glm-4.7"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
